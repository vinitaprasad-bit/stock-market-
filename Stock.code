import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
import time
Main_Menu='''
          -----MAIN MENU-----
          1)Market share data analysis Import to dataframe or
          Export to CSV file.
          2)Market share Data Analysis/Data Manipulation.
          3)Market share Data Visualization.
          4)Exit.'''
plot_menu=''' -----PLOT MENU-----
          1)Line plot Company Vs Target Price and Common Market Price
          2)Bar Graph showing Sum of Target Price Share Type Wise
          3)Barh Company Vs Target Price
          4)Histogram of Common Market Price, Target Price, Realized Returns
          5)Return to Main Menu'''
Analysis_Menu='''  -----SEARCH/ADDITION/DELETION-----
              1)Display all records.
              2)Search records based on Selected columns.
              3)Search records based on Type.
              4)Search records based on Row label/Number(loc[],iloc[]).
              5)Display details of share having maximum target price.
              6)Display details of share having minimum common market price.
              7)Top five records.
              8)Last five records.
              9)Addition of new record to the Dataframe.
              10)Deletion of records from dataframe.
              11)Adittion of New column Total Price to the dataframe.
              12)Display dataframe information.
              13)Display Description of the dataframe(Agrregate function).
              14)Return to Main Menu.'''
import_export_menu=''' -----IMPORT/EXPORT MENU-----
                   1)Import CSV to Dataframe.
                   2)Export dataframe data to CSV file.
                   3)Return to Main Menu.'''

while True:
    print(Main_Menu)
    ch=int(input('Enter your choice'))
    if ch==1:
        while True:
            print(import_export_menu)
            ch3=int(input('Enter your choice'))
            if ch3==1:
                df=pd.read_csv("F:/Projects XII-C 2023-24/Ritika-Simar   Shares Data/market share analysis.csv")
                pd.set_option('display.expand_frame_repr',False)
                pd.set_option('display.max_rows',51)
                print('Content of Dataframe')
                print(df)
                print()
            elif ch3==2:
                df.to_csv('Market Share Analysis.csv',index=False,header=True)
                print('Data Written in [Market Share Analysis.csv] file')
            elif ch3==3:
                print('-----BACK TO MAIN MENU-----')
                break
            else:
                print('WRONG CHOICE')
    elif ch==2:
        while True:
            print(Analysis_Menu)
            ch1=int(input('Enter your Choice'))
            if ch1==1:
                print(df)
                print()
            elif ch1==2:
                print('List of columns are')
                for x in df.columns:
                    print(x,end=',')
