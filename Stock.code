                    if ch in 'nN':
                        break
                print('Details of selected columns')
                print(df[clist])
                print()
            elif ch1==3:
                n=input('Enter Type name')
                df1=df[df.Type==n]
                if df1.empty:
                    print('Sorry NO data for this group')
                else:
                    print(df1)
                    print()
            elif ch1==4:
                print('Available Records Number range',df.index)
                n=int(input('Enter row number you want to display'))
                df1=df.iloc[n]
                if df1.empty:
                    print('NO RECORDS FOUND')
                else:
                    print(df1)
            elif ch1==5:
                df2=df[df.Target_Price== df.Target_Price.max()]
                if df2.empty:
                    print('NO RECORDS FOUND')
                else:
                    print(df2)
                print()
            elif ch1==6:
                df3=df[df.CMP== df.CMP.min()]
                if df3.empty:
                    print('NO RECORDS')
                else:
                    print(df3)
                    print()
            elif ch1==7:
                print('Top Five Records')
                print(df.head())
                print()
            elif ch1==8:
                print('Last five records')
                print(df.tail())
                print()
            elif ch1==9:
                br=input('Enter Company')
                pr=input('Enter Broker')
                ty=input("Enter Type")
                nq=int(input('Enter BatchNo'))
                c=int(input('Enter ShareNo'))
                nos=int(input('Enter Target_Price'))
                cmp=int(input("Enter common market plaec"))
                pf=float(input("Enter profit"))
                rr=float(input("Realization return"))
                df.loc[51]=[nq,br,pr,ty,c,cmp,nos,pf,rr]
                print('RECORD INSERTED')
            elif ch1==10:
                n=int(input('Enter the row index to be deleted'))
                print(df.drop(n,inplace=False))
                print('RECORDE DELETED')
            elif ch1==11:
                df['Total Price']= df.Profit_Ptial + df.Target_Price + df.Realized_Returns
                print(df[['Company','Broker','Total Price']])
                print('COLUMN ADDED')
            elif ch1==12:
                print('DataFame Details')
                print(df.info())
                print()
