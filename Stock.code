                print('Descriptive Statistics')
                print(df.describe())
                print()
            elif ch1==14:
                print('BACK TO MAIN MENU')
                break
            else:
                print('WRONG CHOICE')
    elif ch==3:
            while True:
                print(plot_menu)
                ch2=int(input('Enter your choice'))
                if ch2==1:
                    company=df.Company
                    cmp=df.CMP
                    target=df.Target_Price
                    xdata=np.arange(len(company))
                    plt.plot(xdata,cmp,marker='o',label="Common Market Price")
                    plt.plot(xdata,target,marker='o',label="Target Price")
                    plt.ylabel('Values',fontsize=12)
                    plt.xlabel('Company Name',fontsize=12)
                    plt.legend()
                    plt.xticks(xdata,company,rotation='vertical')
                    plt.title('Company wise Target Price and Common Market Price',fontsize=14)
                    plt.subplots_adjust(bottom=0.3)
                    plt.show()
                elif ch2==2:
                    g=df.groupby('Type')
                    s=g.Target_Price.sum()
                    plt.bar(s.index,s.values,color='r',label='Sum of Target Price')
                    plt.ylabel('Sum of Target Price',fontsize=12)
                    plt.xlabel('Share Type',fontsize=12)
                    plt.title('Type Vs sum of Target Price')
                    plt.legend()
                    plt.subplots_adjust(bottom=0.15)
                    plt.show()
                elif ch2==3:
                    plt.barh(df.Company,df.Target_Price,edgecolor='b')
                    plt.ylabel('Company Name',fontsize=10)
                    plt.xlabel('Target Price',fontsize=12)
                    plt.title('Company Vs Target Price',fontsize=14)
                    plt.subplots_adjust(bottom=0.065)
                    plt.show()
                elif ch2==4:
                    df[['CMP','Target_Price','Realized_Returns']].hist()
                    plt.title("Analysis of CMP, Target & Realized Returns")
                    plt.show()
                elif ch2==5:
                    print('-----BACK TO MAIN MENU-----')
                    break
                else:
                    print('WRONG CHOICE')

